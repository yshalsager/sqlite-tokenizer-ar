static const HonorificExpansion *find_honorific_expansion(const char *text, int nText) {
  int count = (int)(sizeof(HONORIFIC_EXPANSIONS) / sizeof(HONORIFIC_EXPANSIONS[0]));
  for (int i = 0; i < count; i++) {
    const HonorificExpansion *expansion = &HONORIFIC_EXPANSIONS[i];
    if (nText >= expansion->glyphLen && memcmp(text, expansion->glyph, (size_t)expansion->glyphLen) == 0) {
      return expansion;
    }
  }
  return NULL;
}

static int expand_honorific_phrases(const char *text, int nText, char **outText, int *outLen) {
  *outText = NULL;
  *outLen = nText;
  if (text == NULL || nText <= 0) {
    return SQLITE_OK;
  }

  int expandedLen = 0;
  int hasExpansion = 0;
  int idx = 0;
  while (idx < nText) {
    const HonorificExpansion *expansion = find_honorific_expansion(text + idx, nText - idx);
    if (expansion != NULL) {
      int rc = ar_checked_int_sum(expandedLen, expansion->phraseLen, &expandedLen);
      if (rc != SQLITE_OK) {
        return rc;
      }
      idx += expansion->glyphLen;
      hasExpansion = 1;
    } else {
      int rc = ar_checked_int_sum(expandedLen, 1, &expandedLen);
      if (rc != SQLITE_OK) {
        return rc;
      }
      idx++;
    }
  }

  if (!hasExpansion) {
    return SQLITE_OK;
  }

  int allocLen = 0;
  int rc = ar_checked_int_sum(expandedLen, 1, &allocLen);
  if (rc != SQLITE_OK) {
    return rc;
  }
  char *expanded = sqlite3_malloc64((sqlite3_uint64)allocLen);
  if (expanded == NULL) {
    return SQLITE_NOMEM;
  }

  idx = 0;
  int outIdx = 0;
  while (idx < nText) {
    const HonorificExpansion *expansion = find_honorific_expansion(text + idx, nText - idx);
    if (expansion != NULL) {
      memcpy(expanded + outIdx, expansion->phrase, (size_t)expansion->phraseLen);
      outIdx += expansion->phraseLen;
      idx += expansion->glyphLen;
    } else {
      expanded[outIdx++] = text[idx++];
    }
  }
  expanded[outIdx] = '\0';

  *outText = expanded;
  *outLen = expandedLen;
  return SQLITE_OK;
}
